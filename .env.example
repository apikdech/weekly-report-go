# Required
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your-github-username
GWS_EMAIL_SENDER=sender@example.com
REPORT_NAME=Your Full Name
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/run/secrets/gws-credentials

# Google Chat (optional - for Key Metrics / OMTM section)
# GWS_CHAT_SPACES_ID=your-space-id
# GWS_CHAT_SENDER_NAME=users/YOUR_USER_ID

# Docker Compose only (VPS using a pre-built image from GHCR — must match your repo's lowercase ghcr.io path)
# DEPLOY_IMAGE=ghcr.io/your-github-user/gws-weekly-report:main

# Discord Webhook Notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# DISCORD_TIMEOUT=30                      # HTTP timeout in seconds (default: 30)
# DISCORD_RETRY_COUNT=1                   # Number of retries on failure (default: 1)

# LLM Provider Configuration (optional - for Technology Highlights section)
# Provider: gemini | openai | anthropic (default: gemini)
# LLM_PROVIDER=gemini

# API key for the selected provider
# LLM_API_KEY=your-api-key-here

# Model name (provider-specific)
# Gemini: gemini-3-flash, gemini-2.5-pro, gemini-2.0-flash
# OpenAI: gpt-4, gpt-3.5-turbo, gpt-4o
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus
# LLM_MODEL=gemini-3-flash

# Base URL for OpenAI-compatible providers (optional)
# Only used when LLM_PROVIDER=openai
# Leave empty to use default OpenAI API endpoint
# LLM_BASE_URL=

# Legacy variables (backward compatible, will be used if LLM_* not set)
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-3-flash

# General Settings (optional)
# REPORT_TIMEZONE=Asia/Jakarta            # default: UTC
# TEMP_DIR=/tmp

# Comma-separated bullets for the "Next Actions" section (spaces around commas are trimmed)
# REPORT_NEXT_ACTIONS=Debug feature Y, Ship feature X
